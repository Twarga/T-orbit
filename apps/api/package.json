    "redis": "^4.6.0",
    "@cosmic-watch/core-types": "*",
    "@cosmic-watch/validation": "*",
    "@cosmic-watch/observability": "*"
  },
  "devDependencies": {
    "@types/express": "^4.17.0",
    "@types/cors": "^2.8.0",
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0",
    "tsx": "^4.7.0",
    "knex": "^3.1.0"
